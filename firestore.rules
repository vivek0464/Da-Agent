rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Clinic top-level doc: public read (needed by booking page & public APIs)
    match /clinics/{clinicId} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.auth.token.platform_admin == true
            || request.auth.token.clinicId == clinicId);

      // All subcollections: authenticated users belonging to this clinic
      match /{subcollection}/{docId} {
        allow read: if request.auth != null
          && (request.auth.token.platform_admin == true
              || request.auth.token.clinicId == clinicId);
        allow write: if request.auth != null
          && (request.auth.token.platform_admin == true
              || request.auth.token.clinicId == clinicId);
      }
    }
  }
}
