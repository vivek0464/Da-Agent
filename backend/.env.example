# Gemini API (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# Firebase Service Account
# Option 1: path to JSON file (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=
# Option 2: individual env vars (if no path above)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=

# MSG91 SMS (optional — appointment confirmations)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=DOCASG
MSG91_TEMPLATE_ID=
SMS_ENABLED=false

# Server
CORS_ORIGINS=http://localhost:3000,https://dia-clinic.vercel.app

# Platform (used for QR code URL generation)
# Set this to your deployed frontend URL
PLATFORM_URL=https://dia-clinic.vercel.app
